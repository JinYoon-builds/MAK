# Do not put real secrets in this example file.
OPENAI_API_KEY=
OPENAI_LLM_MODEL=gpt-5.4-mini
OPENAI_STT_MODEL=gpt-4o-transcribe
OPENAI_STT_PROMPT=한국어 기차표 예매 키오스크 음성입니다. 사용자는 목적지 역명, 날짜, 시간, 인원수, 예/아니오를 짧게 말합니다. 역명과 발권 표현을 우선 고려하세요.
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=coral
OPENAI_REALTIME_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe

DATA_GO_KR_SERVICE_KEY=
# encoding if you pasted the encoded public-data key, decoding if you pasted decoded key.
DATA_GO_KR_SERVICE_KEY_TYPE=encoding
TAGO_BASE_URL=https://apis.data.go.kr/1613000/TrainInfo

KIOSK_DEFAULT_DEPARTURE_STATION=서울
KIOSK_TIMEZONE=Asia/Seoul
# NAVER Cloud CLOVA Voice TTS
# Set TTS_PROVIDER=clova after filling these values.
TTS_PROVIDER=openai
NCP_CLOVA_VOICE_CLIENT_ID=
NCP_CLOVA_VOICE_CLIENT_SECRET=
CLOVA_VOICE_ID=nara
CLOVA_VOICE_SPEED=-1
CLOVA_VOICE_PITCH=0
CLOVA_VOICE_VOLUME=0
CLOVA_VOICE_FORMAT=mp3
CLOVA_VOICE_URL=https://naveropenapi.apigw.ntruss.com/tts-premium/v1/tts


# NAVER Cloud CLOVA Speech Recognition (CSR) STT
STT_PROVIDER=openai
STT_FINAL_PROVIDER=openai
NCP_CLOVA_SPEECH_CLIENT_ID=
NCP_CLOVA_SPEECH_CLIENT_SECRET=
CLOVA_SPEECH_LANG=Kor
CLOVA_SPEECH_URL=https://naveropenapi.apigw.ntruss.com/recog/v1/stt
